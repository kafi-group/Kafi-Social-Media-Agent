# ============================================
# Kafi Social Agent Backend Environment File
# Copy to .env and customize for your setup
# ============================================

# App Settings
APP_NAME=Kafi Social Agent
# full = entire platform | creation-only = Prompt Studio API only (for junior deployment)
APP_MODE=full
API_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Database Settings (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/kafi_social_agent
DATABASE_ECHO=False
# Seconds to wait for a DB TCP connect before failing (lower = faster UI when DB is down)
DATABASE_CONNECT_TIMEOUT=5

# Supabase Settings (Alternative to local PostgreSQL)
SUPABASE_URL=
SUPABASE_API_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=Media

# Ollama Settings (Local LLM - used when LLM_PROVIDER="ollama")
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_TIMEOUT=300

# Google Gemini Settings (used when LLM_PROVIDER="gemini" - preferred)
# Get a free API key at https://aistudio.google.com/apikey
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# LLM Parameters
TEMPERATURE=0.7
MAX_TOKENS=2048
TOP_P=0.9

# Content Creation chatbot — separate Gemini key from posting (GEMINI_API_KEY above)
# Optional: CREATION_GEMINI_API_KEYS=key2,key3 for quota failover (different Google accounts)
CREATION_GEMINI_API_KEY=
CREATION_GEMINI_API_KEYS=
CREATION_GEMINI_MODEL=gemini-2.5-flash
CREATION_GEMINI_FALLBACK_MODEL=gemini-2.0-flash
# Optional full model chain, e.g. gemini-2.5-flash,gemini-2.0-flash,gemini-2.0-flash-lite
CREATION_GEMINI_MODELS=

# Prompt Studio — image generation
# Provider: cloudflare (free ~230/day) | modelslab (~100/day) | gemini (may need billing)
IMAGE_PROVIDER=cloudflare

# --- ModelsLab (recommended if no Google billing) ---
# Sign up at https://modelslab.com → Dashboard → API key. ~100 free calls/day.
MODELSLAB_API_KEY=
MODELSLAB_IMAGE_MODEL=hidream-o1
MODELSLAB_IMAGE_WIDTH=1024
MODELSLAB_IMAGE_HEIGHT=1024
MODELSLAB_INFERENCE_STEPS=31
MODELSLAB_GUIDANCE_SCALE=7.5
MODELSLAB_CLIP_SKIP=2
MODELSLAB_NEGATIVE_PROMPT=blurry, low quality, distorted, deformed, watermark, ugly
MODELSLAB_IMAGE_TIMEOUT=180

# --- Google Gemini image (set IMAGE_PROVIDER=gemini) ---
IMAGE_GEMINI_API_KEY=
IMAGE_GEMINI_MODEL=gemini-2.5-flash-image
IMAGE_GEMINI_FALLBACK_MODEL=gemini-3.1-flash-image-preview
IMAGE_GEMINI_TIMEOUT=180

# --- Cloudflare Workers AI (set IMAGE_PROVIDER=cloudflare) ---
# Account ID + API token: dash.cloudflare.com → Workers AI → Use REST API
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell
CLOUDFLARE_IMAGE_STEPS=4
CLOUDFLARE_IMAGE_TIMEOUT=120

# Scraper Settings
SCRAPER_TIMEOUT=30
SCRAPER_BATCH_SIZE=10
SCRAPER_SCHEDULE_INTERVAL=3600

# Rival Review (competitor intelligence)
# YouTube Data API v3 key for PUBLIC competitor channel stats (free).
# Create one at https://console.cloud.google.com (enable "YouTube Data API v3").
# Optional if YouTube OAuth below is already configured — rivals will reuse upload OAuth.
# Instagram rival stats reuse FACEBOOK_PAGE_ACCESS_TOKEN + INSTAGRAM_ACCOUNT_ID below.
YOUTUBE_DATA_API_KEY=
# Set True to auto-refresh rival snapshots on SCRAPER_SCHEDULE_INTERVAL.
RIVAL_AUTO_REFRESH=False

# Redis (Optional Caching)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=False

# CORS Origins (localhost + optional explicit production URLs)
# Preview Vercel URLs change every deploy — CORS_ALLOW_VERCEL_REGEX handles *.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://kafi-social-agent.vercel.app
CORS_ALLOW_VERCEL_REGEX=True
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# JWT/Auth
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
# Dashboard login — required to protect API + frontend /dashboard routes
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-this-password

# ---------------------------------------------------------------------------
# Security Hardening
# ---------------------------------------------------------------------------
# Internal API key required by destructive endpoints (e.g. DELETE /content/clear-all).
# Development: leave blank — a key is auto-generated on first run and saved to
#   backend/.internal_api_key (stable across restarts).
# Production/staging: set explicitly. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(40))"
INTERNAL_API_KEY=

# PIN brute-force protection:
# Lock an IP for PIN_LOCKOUT_MINUTES after PIN_MAX_ATTEMPTS consecutive failures.
PIN_MAX_ATTEMPTS=5
PIN_LOCKOUT_MINUTES=15

# Maximum request body size for non-upload endpoints (MB).
MAX_REQUEST_BODY_MB=20

# ---------------------------------------------------------------------------
# Social Media API Credentials
# ---------------------------------------------------------------------------

# LinkedIn (Developer App required: https://www.linkedin.com/developers)
# Account 1 (primary — backward compatible vars)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_ID=
LINKEDIN_ACCOUNT_1_LABEL=Account 1
# Accounts 2 & 3 (optional — posts fan out to all configured accounts)
LINKEDIN_ACCOUNT_2_LABEL=Account 2
LINKEDIN_ACCOUNT_2_ACCESS_TOKEN=
LINKEDIN_ACCOUNT_2_PERSON_ID=
LINKEDIN_ACCOUNT_3_LABEL=Account 3
LINKEDIN_ACCOUNT_3_ACCESS_TOKEN=
LINKEDIN_ACCOUNT_3_PERSON_ID=
LINKEDIN_ORGANIZATION_ID=
# Company-page analytics token (rw_organization_admin). Get via /api/v1/auth/linkedin
LINKEDIN_ORGANIZATION_ACCESS_TOKEN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/v1/auth/linkedin/callback
LINKEDIN_OAUTH_SCOPES=openid profile email rw_organization_admin

# Meta (Facebook & Instagram) - Create App at https://developers.facebook.com
# You need: Facebook Page + Instagram Business Account connected via Meta Business Suite
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_REDIRECT_URI=http://localhost:8000/api/v1/auth/meta/callback
INSTAGRAM_ACCOUNT_ID=
META_GRAPH_API_VERSION=v21.0

# YouTube — OAuth app in Google Cloud Console (see README or docs below)
# While the app is in "Testing", only Google accounts listed as Test users can authorize.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/v1/auth/youtube/callback
YOUTUBE_CHANNEL_ID=
YOUTUBE_VIDEO_CATEGORY_ID=22
# Upload visibility: private | unlisted | public
YOUTUBE_DEFAULT_PRIVACY_STATUS=public

# Draft / Test Mode (True = safe simulation, False = live posting)
DRAFT_MODE=False

# Upload Settings
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50

# ---------------------------------------------------------------------------
# Designer Approval Workflow (QA Checker)
# ---------------------------------------------------------------------------
# When True, non-designers must have their posts approved by the designer.
# Designers enter DESIGNER_PIN to post directly (skipping approval).
APPROVAL_REQUIRED=True
# Shared secret the designer uses to post directly and approve/reject in-app.
DESIGNER_PIN=
