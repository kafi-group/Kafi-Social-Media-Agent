# ============================================
# Kafi Social Agent Backend Environment File
# Copy to .env and customize for your setup
# ============================================

# App Settings
APP_NAME=Kafi Social Agent
API_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Database Settings (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/kafi_social_agent
DATABASE_ECHO=False

# Supabase Settings (Alternative to local PostgreSQL)
SUPABASE_URL=
SUPABASE_API_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=Media

# Ollama Settings (Local LLM - used when LLM_PROVIDER="ollama")
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_TIMEOUT=300

# Google Gemini Settings (used when LLM_PROVIDER="gemini" - preferred)
# Get a free API key at https://aistudio.google.com/apikey
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# LLM Parameters
TEMPERATURE=0.7
MAX_TOKENS=2048
TOP_P=0.9

# Scraper Settings
SCRAPER_TIMEOUT=30
SCRAPER_BATCH_SIZE=10
SCRAPER_SCHEDULE_INTERVAL=3600

# Rival Review (competitor intelligence)
# YouTube Data API v3 key for PUBLIC competitor channel stats (free).
# Create one at https://console.cloud.google.com (enable "YouTube Data API v3").
# Instagram rival stats reuse FACEBOOK_PAGE_ACCESS_TOKEN + INSTAGRAM_ACCOUNT_ID below.
YOUTUBE_DATA_API_KEY=
# Set True to auto-refresh rival snapshots on SCRAPER_SCHEDULE_INTERVAL.
RIVAL_AUTO_REFRESH=False

# Redis (Optional Caching)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=False

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# JWT/Auth
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---------------------------------------------------------------------------
# Security Hardening
# ---------------------------------------------------------------------------
# Internal API key required by destructive endpoints (e.g. DELETE /content/clear-all).
# Development: leave blank — a key is auto-generated on first run and saved to
#   backend/.internal_api_key (stable across restarts).
# Production/staging: set explicitly. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(40))"
INTERNAL_API_KEY=

# Approval email link expiry (hours). Default 48 h; links older than this are rejected.
APPROVAL_TOKEN_EXPIRE_HOURS=48

# PIN brute-force protection:
# Lock an IP for PIN_LOCKOUT_MINUTES after PIN_MAX_ATTEMPTS consecutive failures.
PIN_MAX_ATTEMPTS=5
PIN_LOCKOUT_MINUTES=15

# Maximum request body size for non-upload endpoints (MB).
MAX_REQUEST_BODY_MB=20

# ---------------------------------------------------------------------------
# Social Media API Credentials
# ---------------------------------------------------------------------------

# LinkedIn (Developer App required: https://www.linkedin.com/developers)
# Account 1 (primary — backward compatible vars)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_ID=
LINKEDIN_ACCOUNT_1_LABEL=Account 1
# Accounts 2 & 3 (optional — posts fan out to all configured accounts)
LINKEDIN_ACCOUNT_2_LABEL=Account 2
LINKEDIN_ACCOUNT_2_ACCESS_TOKEN=
LINKEDIN_ACCOUNT_2_PERSON_ID=
LINKEDIN_ACCOUNT_3_LABEL=Account 3
LINKEDIN_ACCOUNT_3_ACCESS_TOKEN=
LINKEDIN_ACCOUNT_3_PERSON_ID=
LINKEDIN_ORGANIZATION_ID=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Meta (Facebook & Instagram) - Create App at https://developers.facebook.com
# You need: Facebook Page + Instagram Business Account connected via Meta Business Suite
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
META_GRAPH_API_VERSION=v18.0

# YouTube Analytics requires a refresh token minted with yt-analytics.readonly
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=
YOUTUBE_VIDEO_CATEGORY_ID=22

# Draft / Test Mode (True = safe simulation, False = live posting)
DRAFT_MODE=True

# Upload Settings
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50

# ---------------------------------------------------------------------------
# Designer Approval Workflow (QA Checker)
# ---------------------------------------------------------------------------
# When True, non-designers must have their posts approved by the designer.
# Designers enter DESIGNER_PIN to post directly (skipping approval).
APPROVAL_REQUIRED=True
# Shared secret the designer uses to post directly and approve/reject in-app.
DESIGNER_PIN=
# Email address that receives approval requests with Approve/Reject links.
DESIGNER_EMAIL=
# Public base URL of this backend (used for media URLs + email action links).
# For production set this to your deployed backend URL so email links/images work.
BACKEND_PUBLIC_URL=http://localhost:8000

# SMTP (Gmail) for sending approval emails.
# Use a Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=True
